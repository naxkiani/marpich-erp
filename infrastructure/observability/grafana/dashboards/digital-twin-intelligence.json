{
  "title": "Marpich Digital Twin Intelligence",
  "uid": "marpich-twin-intelligence-p199d22",
  "tags": ["digital-twin", "ai", "p199-d2.2"],
  "panels": [
    {
      "title": "Prediction Requests",
      "type": "stat",
      "targets": [{ "expr": "increase(marpich_twin_prediction_requests_total[1h])" }]
    },
    {
      "title": "Prediction Latency p95 (ms)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(marpich_twin_inference_latency_ms_bucket[5m])) by (le))" }]
    },
    {
      "title": "Prediction Failures",
      "type": "timeseries",
      "targets": [{ "expr": "rate(marpich_twin_prediction_failures_total[5m])" }]
    },
    {
      "title": "Simulation Runs",
      "type": "stat",
      "targets": [{ "expr": "increase(marpich_twin_simulation_runs_total[1h])" }]
    },
    {
      "title": "Graph Query Latency p95 (ms)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(marpich_twin_graph_query_seconds_bucket[5m])) by (le)) * 1000" }]
    },
    {
      "title": "Graph Nodes / Edges",
      "type": "stat",
      "targets": [
        { "expr": "marpich_twin_graph_nodes" },
        { "expr": "marpich_twin_graph_edges" }
      ]
    }
  ]
}
