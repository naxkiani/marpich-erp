{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://marpich.dev/schemas/integration/connectors/payment_gateway.v1.json",
  "title": "Payment Gateway Connector Config",
  "type": "object",
  "required": ["provider", "environment"],
  "additionalProperties": false,
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["stripe", "paypal", "adyen", "local_psp", "custom"]
    },
    "environment": { "type": "string", "enum": ["sandbox", "production"] },
    "webhook_endpoint_id": { "type": "string" },
    "secret_ref": { "type": "string" },
    "currency_default": { "type": "string", "pattern": "^[A-Z]{3}$" }
  }
}
