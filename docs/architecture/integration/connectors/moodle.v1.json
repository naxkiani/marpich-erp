{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://marpich.dev/schemas/integration/connectors/moodle.v1.json",
  "title": "Moodle Connector Config",
  "type": "object",
  "required": ["base_url", "environment"],
  "additionalProperties": true,
  "properties": {
    "base_url": { "type": "string", "format": "uri" },
    "environment": { "type": "string", "enum": ["sandbox", "production"] },
    "secret_ref": { "type": "string", "description": "Vault reference for Moodle token" },
    "site_id": { "type": "string" },
    "fixtures": {
      "type": "object",
      "description": "Sandbox fixture overrides for courses/enrollments/grades"
    }
  }
}
