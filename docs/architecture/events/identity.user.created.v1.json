{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "marpich.identity.user.created.v1",
  "title": "identity.user.created",
  "description": "Published when a new user is registered within a tenant",
  "type": "object",
  "required": ["event_id", "event_name", "event_version", "source_context", "tenant_id", "correlation_id", "occurred_at", "payload"],
  "properties": {
    "event_name": { "const": "identity.user.created" },
    "event_version": { "const": 1 },
    "source_context": { "const": "identity" },
    "tenant_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$" },
    "payload": {
      "type": "object",
      "required": ["user_id", "email", "display_name"],
      "properties": {
        "user_id": { "type": "string", "format": "uuid" },
        "email": { "type": "string", "format": "email" },
        "display_name": { "type": "string" },
        "role_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
      }
    }
  }
}
