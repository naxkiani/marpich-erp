{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "marpich.integration.envelope.v1",
  "title": "Integration Event Envelope",
  "description": "Base contract for all cross-context integration events — immutable append-only",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "event_version",
    "source_context",
    "tenant_id",
    "organization_id",
    "correlation_id",
    "occurred_at",
    "user_id",
    "security_context",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
    "event_version": { "type": "integer", "minimum": 1 },
    "source_context": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 63 },
    "organization_id": {
      "type": ["string", "null"],
      "description": "Organization unit within tenant; null for platform-only events"
    },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_id": { "type": ["string", "null"] },
    "occurred_at": { "type": "string", "description": "ISO-8601 UTC timestamp" },
    "user_id": {
      "type": ["string", "null"],
      "description": "Actor who caused the fact; null for system jobs"
    },
    "security_context": {
      "type": "object",
      "required": ["auth_method", "scopes"],
      "additionalProperties": false,
      "properties": {
        "auth_method": {
          "type": "string",
          "enum": ["jwt", "oauth2_client", "system", "integration", "api_key"]
        },
        "ip_address": { "type": ["string", "null"] },
        "user_agent": { "type": ["string", "null"] },
        "scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "session_id": { "type": ["string", "null"] }
      }
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
