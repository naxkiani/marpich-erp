# Platform
NODE_ENV=development
PLATFORM_NAME=Marpich ERP
PLATFORM_VERSION=0.1.0

# PostgreSQL
DATABASE_URL=postgresql://marpich:marpich@localhost:5432/marpich_platform
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379

# Kafka / Event Bus
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BROKERS=localhost:9092
EVENT_BUS_DRIVER=kafka

# Multi-tenant
TENANT_RESOLUTION_STRATEGY=subdomain
DEFAULT_TENANT_SCHEMA=public

# Identity Service
IDENTITY_SERVICE_PORT=4001
IDENTITY_PERSISTENCE=memory

# JWT
JWT_SECRET=change-me-in-production-use-256-bit-key
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# API Gateway
API_GATEWAY_PORT=4000
IDENTITY_SERVICE_URL=http://localhost:4001
TENANT_SERVICE_URL=http://localhost:4002
MODULE_REGISTRY_URL=http://localhost:4003

# AI Layer
AI_SERVICE_URL=http://localhost:4010
AI_PROVIDER=openai
OPENAI_API_KEY=
