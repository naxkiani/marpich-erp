# Marpich ERP — Python backend (local platform)
PERSISTENCE_BACKEND=postgres
DATABASE_URL=postgresql+asyncpg://marpich:marpich@127.0.0.1:5432/marpich_platform

JWT_SECRET=change-me-in-production-use-256-bit-key
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
# Document Exchange — QR MAC secret + RSA-PSS content signing (PEMs; HSM via Secrets later)
DOCUMENT_SIGNING_SECRET=change-me-documents-signing-secret
# DOCUMENT_SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# DOCUMENT_SIGNING_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# DOCUMENT_SIGNING_KEY_ID=documents-signing-v1

# LiveKit (Integration connector — real JWT when API key+secret set; else simulated lk_ tokens)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_TOKEN_TTL_SECONDS=3600

# Event fabric
EVENT_BUS_MODE=direct
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# Cache
REDIS_URL=redis://127.0.0.1:6379
AUTHZ_DECISION_CACHE_BACKEND=memory

# Observability (optional — enable with docker compose --profile observability)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=marpich-backend
OTEL_ENVIRONMENT=development

# App profile: core | enterprise | financial | banking | industry | test | full
MARPICH_APP_PROFILE=full
